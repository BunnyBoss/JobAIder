# ==========================================
# JobAIder Deployment Environment Variables
# ==========================================

# 1. API Keys (Required for backend LLM processing)
#MODEL_NAME="mistral-chat-mistral-large-latest"
MODEL_NAME="mistral-large-2512"
#OPENAI_BASE_URL="http://host.docker.internal:4000/"
OPENAI_BASE_URL="https://api.mistral.ai/v1"

# 2. Security
# Change this to a long random string in production!
# e.g., openssl rand -hex 32
SECRET_KEY="password"

# 3. Network & CORS Configuration
# NEXT_PUBLIC_API_BASE tells the user's browser where to reach the backend API.
# - For local Docker testing: http://localhost:8000
# - For production: https://api.yourdomain.com
#NEXT_PUBLIC_API_BASE="https://poorna-deploy-wnqnk-8000.icecloud.in"

# ALLOWED_ORIGINS tells the backend which domains are allowed to make requests.
# - For local Docker testing: http://localhost:3000
# - For production: https://yourdomain.com
#ALLOWED_ORIGINS="https://poorna-deploy-wnqnk-3000.icecloud.in"
